<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Сергей Владимирович | ГК СЭТ</title>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="style.css">
</head>

<body>

<header class="hero">
    <div class="hero-text fade">
        <p class="mini">ГК «СЭТ»</p>
        <h1>Сергей Владимирович</h1>
        <p>Генеральный директор экологической компании</p>
        <a href="#bio" class="btn">Узнать больше</a>
    </div>
</header>

<section id="bio" class="bio fade">
    <h2>Биография</h2>
    <p>
        Сергей Владимирович — генеральный директор ГК «СЭТ», руководитель,
        чья деятельность связана с развитием экологических технологий,
        современным подходом к защите окружающей среды и ответственным
        управлением экологическими проектами.
    </p>
</section>

<section class="main-photo fade">
    <img src="img1.png" alt="Сергей Владимирович с наградой">

    <div class="photo-text">
        <h2>Лучшая компания</h2>
        <p>
            Под руководством Сергея Владимировича ГК «СЭТ» развивает
            экологические инициативы и формирует образ компании,
            ориентированной на качество, ответственность и будущее.
        </p>
    </div>
</section>

<section class="contact fade">
    <p class="mini">Связаться с компанией</p>
    <h2>Контакты</h2>

    <p>📞 <a href="tel:+9101559606">+9101559606</a></p>
    <p>✉️ <a href="mailto:89101525191@mail.ru">89101525191@mail.ru</a></p>
</section>

<script>
const items = document.querySelectorAll('.fade');

const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
        if (e.isIntersecting) {
            e.target.classList.add('show');
        }
    });
});

items.forEach(el => obs.observe(el));
</script>

</body>
</html>
html {
    scroll-behavior: smooth;
}

body {
    margin: 0;
    background: #050505;
    color: white;
    font-family: 'Inter', sans-serif;
}

/* HERO */
.hero {
    min-height: 100vh;
    background:
        linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.85)),
        radial-gradient(circle at center, #15382c, #000);
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
}

.hero-text {
    max-width: 800px;
    padding: 30px;
}

.hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: 76px;
    margin: 10px 0;
}

.hero p {
    font-size: 20px;
    opacity: 0.8;
}

.mini {
    letter-spacing: 4px;
    text-transform: uppercase;
    font-size: 13px;
    opacity: 0.55;
}

.btn {
    display: inline-block;
    margin-top: 30px;
    padding: 15px 34px;
    border: 1px solid rgba(255,255,255,0.7);
    border-radius: 40px;
    color: white;
    text-decoration: none;
    transition: 0.3s;
}

.btn:hover {
    background: white;
    color: black;
}

/* BIO */
.bio {
    padding: 100px 20%;
    text-align: center;
}

.bio h2,
.photo-text h2,
.contact h2 {
    font-family: 'Playfair Display', serif;
    font-size: 44px;
}

.bio p {
    font-size: 18px;
    line-height: 1.8;
    opacity: 0.78;
}

/* MAIN PHOTO */
.main-photo {
    position: relative;
    width: 80%;
    margin: 0 auto 100px;
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0,0,0,0.6);
}

.main-photo img {
    width: 100%;
    display: block;
}

.main-photo::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.75), transparent 60%);
}

.photo-text {
    position: absolute;
    left: 50px;
    bottom: 45px;
    max-width: 600px;
    z-index: 2;
}

.photo-text p {
    line-height: 1.7;
    opacity: 0.85;
}

/* CONTACT */
.contact {
    text-align: center;
    padding: 100px 10%;
    background: radial-gradient(circle, #111, #000);
}

.contact a {
    color: white;
    font-size: 20px;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.35);
}

.contact a:hover {
    border-bottom: 1px solid white;
}

/* ANIMATION */
.fade {
    opacity: 0;
    transform: translateY(45px);
    transition: 1s ease;
}

.fade.show {
    opacity: 1;
    transform: translateY(0);
}

/* MOBILE */
@media (max-width: 768px) {
    .hero h1 {
        font-size: 42px;
    }

    .bio {
        padding: 60px 10%;
    }

    .main-photo {
        width: 92%;
    }

    .photo-text {
        left: 25px;
        bottom: 25px;
        right: 25px;
    }

    .photo-text h2 {
        font-size: 32px;
    }
}
